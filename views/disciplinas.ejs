<h1>Gerenciar Disciplinas</h1>

<hr>

<table border="1" cellpadding="8">
<tr>
    <th>ID</th>
    <th>Disciplina</th>
    <th>Curso</th>
    <th>Turma</th>
    <th>Professor</th>
    <th>Ações</th>
</tr>

<% if (disciplinas.length === 0) { %>
<tr>
    <td colspan="6">Nenhuma disciplina cadastrada.</td>
</tr>
<% } %>

<% disciplinas.forEach(d => { %>
<tr>
    <td><%= d.id %></td>
    <td><%= d.nome %></td>
    <td><%= d.curso %></td>
    <td><%= d.turma %></td>
    <td><%= d.professor %></td>
    <td>
        <a href="/academico/gerenciar/disciplinas/editar/<%= d.id %>">
            <button>Editar</button>
        </a>

        <a href="/academico/gerenciar/disciplinas/excluir/<%= d.id %>"
           onclick="return confirm('Deseja excluir esta disciplina?')">
            <button style="background:red;color:white;">Excluir</button>
        </a>
    </td>
</tr>
<% }) %>
</table>

<br>
<a href="/admin"><button>Voltar</button></a>