<h1>Gerenciar Turmas</h1>

<p>Usuário: <strong><%= user.nome %></strong></p>

<hr>

<table border="1" cellpadding="8">
    <tr>
        <th>ID</th>
        <th>Nome da Turma</th>
        <th>Curso</th>
        <th>Ações</th>
    </tr>

    <% if (turmas.length === 0) { %>
        <tr>
            <td colspan="4">Nenhuma turma cadastrada.</td>
        </tr>
    <% } %>

    <% turmas.forEach(t => { %>
        <tr>
            <td><%= t.id %></td>
            <td><%= t.nome %></td>
            <td><%= t.curso %></td>
            <td>
                <a href="/academico/gerenciar/turmas/editar/<%= t.id %>">
                    <button>Editar</button>
                </a>

                <a href="/academico/gerenciar/turmas/excluir/<%= t.id %>"
                   onclick="return confirm('Tem certeza que deseja excluir esta turma?')">
                    <button style="background:red;color:white;">Excluir</button>
                </a>
            </td>
        </tr>
    <% }) %>
</table>

<br>
<a href="/admin"><button>Voltar ao Painel</button></a>