<h1>Gestão de Cursos</h1>

<h3>Cadastrar Curso</h3>

<form method="POST" action="/academico/cursos/criar">
    <input type="text" name="nome" placeholder="Nome do Curso" required>
    <br><br>
    <textarea name="descricao" placeholder="Descrição"></textarea>
    <br><br>
    <button type="submit">Criar</button>
</form>

<hr>

<table border="1">
<tr>
    <th>ID</th>
    <th>Nome</th>
    <th>Descrição</th>
    <th>Ações</th>
</tr>

<% cursos.forEach(c => { %>
<tr>
    <td><%= c.id %></td>
    <td><%= c.nome %></td>
    <td><%= c.descricao %></td>
    <td>
        <a href="/academico/cursos/editar/<%= c.id %>">Editar</a> |
        <a href="/academico/cursos/excluir/<%= c.id %>">Excluir</a>
    </td>
</tr>
<% }) %>
</table>

<br>
<a href="/admin">Voltar</a>